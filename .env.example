# France Travail — OAuth2 Client Credentials
# Créer une application sur https://francetravail.io (realm /partenaire).
# Scopes utilisés : api_offresdemploiv2 o2dsoffre
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# GCP / BigQuery
GCS_BUCKET_NAME=datatalent-raw-simplon
BQ_PROJECT_ID=datatalent-simplon

# Base SQLite (optionnel). Si la base est sur le côté Windows pour DBeaver,
# indiquer le chemin depuis WSL, ex. :
# DATABASE_PATH=/mnt/c/Users/antoi/Downloads/local.db
# DATABASE_PATH=
